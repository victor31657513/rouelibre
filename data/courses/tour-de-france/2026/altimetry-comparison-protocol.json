    "configurationRules": [
      "fully-declared-before-execution",
      "si-units",
      "identical-for-all-inputs",
      "no-manual-per-track-or-per-case-adjustment",
      "no-hidden-thresholds",
      "defensively-copied-and-deeply-immutable"
    ],
    "adaptiveRule": "Une adaptation intrinsèque est admise seulement si sa règle explicite et déterministe appartient à l'algorithme et ne lit aucun nom de fichier, identifiant d'étape ou cas du manifeste."
