  "measurementConventions": {
    "preparedAltitudeAtSourceDistance": {
      "profileModel": "piecewise-linear-between-successive-prepared-points",
      "exactDistanceRule": "Si la distance source correspond exactement à une distance préparée, utiliser son altitude.",
      "interpolationFormula": "t = (d - d0) / (d1 - d0); preparedAltitudeAtSourceDistance = altitude0 + t * (altitude1 - altitude0)",
      "extrapolationAllowed": false,
      "role": "measurement-only-not-preparation"
    },
    "intervals": {
      "deltaAltitudeFormula": "endAltitude - startAltitude",
      "gradeFormula": "deltaAltitudeMeters / horizontalSpacingMeters"
    },
    "percentiles": {
      "method": "empirical-nearest-rank",
      "formula": "p = 0 selects index 0; otherwise index = ceil((p / 100) * N) - 1 after ascending sort",
      "interpolation": false,
      "tieBreak": "first-observation-in-document-order"
    },
    "corrections": {
      "formula": "preparedAltitudeAtSourceDistance - sourceAltitudeMeters",
      "changedComparison": "exactly-not-equal-to-zero",
      "meanAbsoluteFormula": "sum(abs(correctionMeters)) / sourcePointCount",
      "rootMeanSquareFormula": "sqrt(sum(correctionMeters * correctionMeters) / sourcePointCount)",
      "maximumTieBreak": "first-source-point-index",
      "validationThreshold": false
    }
  },
